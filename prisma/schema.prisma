// ============================================================
// SCHEMA PRISMA — Tríade Painel de Afiliados
// IDs: UUID v4 (não sequencial) para segurança
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUÁRIOS / AFILIADOS
// ============================================================
model User {
  id           String   @id @default(uuid())

  name         String
  email        String   @unique
  passwordHash String

  // Perfil de acesso
  role         Role     @default(AFFILIATE)

  // ID do afiliado na casa de aposta
  externalId   String?

  // Código de convite do sistema Tríade (gerado automaticamente, único)
  inviteCode   String?  @unique

  // CPA definido pelo admin/upline
  cpaValue     Decimal  @default(0) @db.Decimal(10, 2)

  // Dados de pagamento PIX
  pixKeyType   String?
  pixKey       String?

  // Dados extras do afiliado (cadastro)
  whatsapp     String?
  instagram    String?
  market       String?
  ftdsEstimate String?

  // Hierarquia de rede
  referrerId   String?
  referrer     User?    @relation("Network", fields: [referrerId], references: [id])
  referrals    User[]   @relation("Network")

  // Status do afiliado
  status       UserStatus @default(PENDING)

  // Refresh token (rotacionado a cada login)
  refreshToken String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  affiliateLinks   AffiliateLink[]
  playerStats      PlayerStat[]
  commissions      Commission[]
  payments         Payment[]
  approvals        Approval[]
  nfes             Nfe[]
  betRequests      BetAccessRequest[] @relation("UserBetRequests")
  reviewedRequests BetAccessRequest[] @relation("ReviewedBetRequests")
  activityLogs     ActivityLog[]

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  TEAM_ADMIN
  AFFILIATE
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// SOLICITAÇÕES DE ACESSO A CASAS DE APOSTA
// ============================================================
model BetAccessRequest {
  id             String @id @default(uuid())

  userId         String
  user           User   @relation("UserBetRequests", fields: [userId], references: [id])

  bettingHouseId String
  bettingHouse   BettingHouse @relation(fields: [bettingHouseId], references: [id])

  status         BetAccessStatus @default(PENDING)

  reviewedById   String?
  reviewedBy     User?  @relation("ReviewedBetRequests", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, bettingHouseId])
  @@map("bet_access_requests")
}

enum BetAccessStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// CASAS DE APOSTA
// ============================================================
model BettingHouse {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique

  apiBaseUrl  String?
  apiKey      String?
  apiSecret   String?

  // Suporte
  supportWhatsapp String?

  // Dados fiscais para emissão de NFE pelo afiliado
  fiscalName      String?   // Razão Social
  fiscalFantasy   String?   // Nome Fantasia
  fiscalCnpj      String?
  fiscalCnae      String?
  fiscalNote      String?   // Aviso/instrução adicional

  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  affiliateLinks   AffiliateLink[]
  playerStats      PlayerStat[]
  materials        Material[]
  betAccessRequests BetAccessRequest[]

  @@map("betting_houses")
}

// ============================================================
// LINKS DE AFILIADO
// ============================================================
model AffiliateLink {
  id    String @id @default(uuid())

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  bettingHouseId String
  bettingHouse   BettingHouse @relation(fields: [bettingHouseId], references: [id])

  refCode  String
  dbCode   String?
  fullUrl  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("affiliate_links")
}

// ============================================================
// ESTATÍSTICAS DE JOGADORES
// ============================================================
model PlayerStat {
  id    String @id @default(uuid())

  userId         String
  user           User         @relation(fields: [userId], references: [id])

  bettingHouseId String
  bettingHouse   BettingHouse @relation(fields: [bettingHouseId], references: [id])

  date          DateTime

  registrations Int     @default(0)
  cpas          Int     @default(0)
  ftds          Int     @default(0)
  deposits      Decimal @default(0) @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bettingHouseId, date])
  @@map("player_stats")
}

// ============================================================
// COMISSÕES
// ============================================================
model Commission {
  id     String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id])

  amount      Decimal  @db.Decimal(15, 2)
  periodStart DateTime
  periodEnd   DateTime
  status      CommissionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("commissions")
}

enum CommissionStatus {
  PENDING
  PAID
}

// ============================================================
// PAGAMENTOS
// ============================================================
model Payment {
  id     String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id])

  amount   Decimal @db.Decimal(15, 2)
  pixKey   String
  status   PaymentStatus @default(PENDING)

  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PAID
  REJECTED
}

// ============================================================
// APROVAÇÕES
// ============================================================
model Approval {
  id     String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id])

  status     ApprovalStatus @default(PENDING)
  cpaValue   Decimal?       @db.Decimal(10, 2)
  reviewedAt DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// NOTAS FISCAIS
// ============================================================
model Nfe {
  id     String @id @default(uuid())

  userId String
  user   User @relation(fields: [userId], references: [id])

  periodFrom      DateTime
  periodTo        DateTime
  emailPlatform   String

  bankName        String?
  bankAgency      String?
  bankAccount     String?
  bankAccountType String?

  pixKeyType      String?
  pixKey          String?

  pdfPath         String?
  status          NfeStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("nfes")
}

enum NfeStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// LOG DE ATIVIDADE
// ============================================================
model ActivityLog {
  id        String   @id @default(uuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  // Ação curta e legível, ex: "login", "create_house:Sportingbet", "approve_user:João"
  action    String

  ip        String?

  createdAt DateTime @default(now())

  @@map("activity_logs")
}

// ============================================================
// MATERIAIS
// ============================================================
model Material {
  id   String @id @default(uuid())
  name String
  type String  // banner | video | pdf | outro

  url      String
  isActive Boolean @default(true)

  bettingHouseId String?
  bettingHouse   BettingHouse? @relation(fields: [bettingHouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("materials")
}
