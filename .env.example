# ============================================================
# BANCO DE DADOS
# ============================================================
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable"

# ============================================================
# SERVIDOR
# ============================================================
PORT=3333
NODE_ENV=production

# Origens permitidas pelo CORS (obrigatório em produção, separar por vírgula)
# Exemplo: https://seudominio.com,https://www.seudominio.com
ALLOWED_ORIGINS=https://seudominio.com

# ============================================================
# AUTENTICAÇÃO
# ============================================================
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# ============================================================
# CASAS DE APOSTA — preencher quando tiver as docs das APIs
# ============================================================
# SUPERBET_API_BASE_URL=
# SUPERBET_API_KEY=
# SUPERBET_API_SECRET=
